  "publicApiSurface": [
    "POST /api/login - Autenticación de usuarios",
    "POST /api/ventas - Crear factura o boleta",
    "POST /api/notas-credito - Emitir nota de crédito",
    "POST /api/notas-debito - Emitir nota de débito",
    "POST /api/guias-remision - Crear guía de remisión",
    "GET /api/ventas - Listar ventas",
    "POST /api/ventas/{id}/enviar-sunat - Enviar comprobante a SUNAT",
    "POST /api/ventas/{id}/anular - Anular venta",
    "GET /api/cotizaciones - Listar cotizaciones",
    "POST /api/cotizaciones - Crear cotización",
    "GET /api/productos - Listar productos",
    "POST /api/productos - Crear producto",
    "GET /api/clientes - Listar clientes",
    "POST /api/clientes - Crear cliente",
    "GET /api/proveedores - Listar proveedores",
    "POST /api/compras - Registrar compra",
    "GET /api/dashboard/stats - Estadísticas del dashboard",
    "POST /api/switch-empresa - Cambiar empresa activa"
  ]
